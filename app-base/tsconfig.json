{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@dating/core": ["../packages/@dating/core/src/index.ts"],
      "@dating/core/*": ["../packages/@dating/core/src/*"],
      "@dating/ui": ["../packages/@dating/ui/src/index.ts"],
      "@dating/ui/*": ["../packages/@dating/ui/src/*"]
    }
  },
  "include": ["src", "../packages/@dating/core/src", "../packages/@dating/ui/src"]
}
